unit 
  lcu;

interface

  uses
    lcommon,
    lliteral,
    lcbase,
    utils;

  var
    verbose: boolean;

  procedure startBuild(const filename: string);

implementation

  procedure pushState(var stack: TStateStack; value: EState);
  begin
    with stack do
      if stack.count = C_STATE_STACK_SIZE then
        raise('State stack overflow')
      else begin
        stack.values[stack.count] := value;
        count := count + 1;
      end;
  end;

  procedure popState(var stack: TStateStack);
  begin
    with stack do
      if count = 0 then
        raise('State stack empty')
      else begin
        count := count - 1;
        state := values[count];
      end;  
  end;

  procedure doStart;
  begin
    with build, stack do
    begin
      ch := readChar;
      if ch = #0 then
        state := EStateEnd
      else if ch in C_SPACING_CHARS then
      begin
        pushState(stack, EStateReadInstruction);
        state := EStateSkipSpacesAndLineBreaks;
      end else 
        state := EStateReadInstruction;
    end;
  end;

  procedure doCommentUntilLineBreak;
  begin
    with build do
      if ch <> C_LF then
        ch := readChar
      else
        popState(stack);
  end;

  procedure doSkipSpacesAndLineBreaks;
  begin
    with build do
      if (ch = C_LF) then
      begin
        inc(lineNumber);
        lineCharacter := 1;
        ch := readChar;
      end else if ch = '#' then
        stack.state := EStateCommentUntilLineBreak  
      else if ch in C_SPACING_CHARS then
        ch := readChar
      else
        popState(stack);
  end;

  procedure doSkipSpaces;
  begin
    with build do
      if ch in [C_SPACE, C_TAB, C_CR] then
        ch := readChar
      else if ch = '#' then
        stack.state := EStateCommentUntilLineBreak  
      else
        popState(stack);
  end;

  procedure doReadInstruction;
  var
    result: boolean;
  begin
    with build, instructionData, stack do
      if ch = #0 then
        state := EStateEnd
      else if ch in ['a'..'z'] then
      begin 
        name := name + ch;
        ch := readChar;
      end else if ch in [C_SPACE, C_CR, C_LF] then
      begin
        result := getOpcodeInfoByName(name, opcode, expectedParamCount);
        if result then
        begin
          if ch in [C_CR, C_LF] then
            state := EStateBuildBinaryInstruction
          else begin
            pushState(stack, EStateReadParam0);
            state := EStateSkipSpaces;
          end;
        end else
        begin
          lineCharacter := lineCharacter - length(name) - 1;
          raise('unknown instruction "' + name + '" unknown');
        end;
      end else
      begin
        raise('unexpected character "' + ch + '" #' + intToStr(ord(ch)));
        state := EStateEnd;
      end;
  end;

  procedure doReadParam0;
  begin
    with build, instructionData, stack do
      if ch in [#0, C_CR, C_LF, ','] then
      begin
        if ch = ',' then
        begin
          ch := readChar;
          pushState(stack, EStateReadParam1);
          state := EStateSkipSpaces;
        end else
          state := EStateBuildBinaryInstruction;
      end else begin
        param0 := param0 + ch;
        ch := readChar;
      end;
  end;

  procedure doReadParam1;
  begin
    with build, instructionData, stack do
      if ch in [#0, C_CR, C_LF] then
        state := EStateBuildBinaryInstruction
      else begin
        param1 := param1 + ch;
        ch := readChar;
      end;
  end;

  procedure doBuildBinaryInstruction;
  begin
    with build do
    begin
      validateParams;

      if verbose then 
        with instructionData do writeln('    (', name, ', ', param0, ', ', param1, ')');

      if ch = #0 then
        stack.state := EStateEnd
      else begin
        inc(instructionCount);
        fillchar(instructionData, sizeof(instructionData), 0);
        stack.state := EStateStart;
      end;
    end;
  end;

  procedure startBuild(const filename: string);
  begin
    initBuild(filename);
    with build, stack do
    begin
      assign(sourceFile, sourceFileName);
      {$I-} reset(build.sourceFile, 1); {$I+}
      isOpen := IOResult = 0;
      if not isOpen then raise('"' + sourceFileName + '" not found or invalid');
      message('building "' + sourceFileName + '"');
      while state <> EStateEnd do
        case state of
          EStateStart: doStart;
          EStateSkipSpacesAndLineBreaks: doSkipSpacesAndLineBreaks;
          EStateReadInstruction: doReadInstruction;
          EStateReadParam0: doReadParam0;
          EStateReadParam1: doReadParam1;
          EStateSkipSpaces: doSkipSpaces;
          EStateCommentUntilLineBreak: doCommentUntilLineBreak;
          EStateBuildBinaryInstruction: doBuildBinaryInstruction;
        end;
      message('Ended successfully')
    end;
  end;

begin
  verbose := false;
end.